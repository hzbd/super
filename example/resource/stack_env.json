{
  "prune": false,
  "services": [
    {
      "name": "celery-worker",
      "group": "workers",

      "numprocs": 4,
      "process_name": "worker-{num}",

      "command": "/usr/bin/python3",
      "args": ["-m", "celery", "worker"],

      "env": {
        "FLASK_ENV": "production",
        "DB_HOST": "192.168.1.50",
        "DB_PORT": "5432",
        "SECRET_KEY": "sk_prod_123456"
      },

      "autostart": true
    }
  ]
}
